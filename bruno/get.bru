meta {
  name: get
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/get?source=bruno-action
}

assert {
  res.status: eq 200
  res.body.args.source: eq bruno-action
}

tests {
  test("response echoes the query string", function() {
    expect(res.getBody().args.source).to.equal("bruno-action");
  });
}
