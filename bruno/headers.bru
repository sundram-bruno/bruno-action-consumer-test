meta {
  name: headers
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/headers
}

headers {
  X-Bruno-Run: ci
}

assert {
  res.status: eq 200
  res.body.headers.X-Bruno-Run: eq ci
}

tests {
  test("custom header round-trips", function() {
    expect(res.getBody().headers["X-Bruno-Run"]).to.equal("ci");
  });
}
